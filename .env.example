# Inertia Environment Configuration
# Copy this to .env and fill in your values

# Redis
REDIS_URL=redis://inertia-redis:6379

# Qdrant
QDRANT_HOST=inertia-qdrant
QDRANT_PORT=6333

# Ollama — model is pulled automatically on first boot (~2GB)
OLLAMA_URL=http://inertia-ollama:11434
OLLAMA_MODEL=llama3.2

# Webhook HMAC secret — change this in production
WEBHOOK_SECRET=change_this_to_a_strong_random_secret

# Isolation Forest
IF_CONTAMINATION=0.05
IF_N_ESTIMATORS=100

# DB path (inside container volume)
DB_PATH=/data/inertia.db
